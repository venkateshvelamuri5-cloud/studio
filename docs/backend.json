
{
  "entities": {
    "User": {
      "title": "User",
      "description": "A student rider, driver, or administrative user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "collegeName": { "type": "string" },
        "studentId": { "type": "string" },
        "licenseNumber": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "vehicleType": { "type": "string", "enum": ["Bus", "Mini-Bus", "Van"] },
        "city": { "type": "string", "enum": ["Vizag", "Vizianagaram"] },
        "role": { "type": "string", "enum": ["rider", "admin", "driver"] },
        "status": { "type": "string", "enum": ["available", "on-trip", "offline"] },
        "currentLat": { "type": "number" },
        "currentLng": { "type": "number" },
        "totalTrips": { "type": "number", "default": 0 },
        "credits": { "type": "number", "default": 0 },
        "totalEarnings": { "type": "number", "default": 0, "description": "Cumulative earnings for drivers (90% share)." },
        "weeklyEarnings": { "type": "number", "default": 0, "description": "Current week's earnings for drivers." },
        "createdAt": { "type": "string", "format": "date-time" },
        "activeOtp": { "type": "string", "description": "Temporary 6-digit OTP for boarding verification." }
      },
      "required": ["uid", "fullName", "role"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A record of a shuttle trip.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "routeName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
        "riderCount": { "type": "number" },
        "farePerRider": { "type": "number" },
        "surgeFare": { "type": "number", "default": 0 },
        "totalFareCollected": { "type": "number" },
        "commissionAmount": { "type": "number", "description": "10% platform share." },
        "payoutAmount": { "type": "number", "description": "90% driver share." },
        "passengers": { "type": "array", "items": { "type": "string" } },
        "verifiedPassengers": { "type": "array", "items": { "type": "string" } },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      },
      "required": ["driverId", "routeName", "status"]
    },
    "Route": {
      "title": "Route",
      "description": "An optimized shuttle route configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "routeName": { "type": "string" },
        "description": { "type": "string" },
        "stops": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          } 
        },
        "city": { "type": "string", "enum": ["Vizag", "Vizianagaram"] },
        "baseFare": { "type": "number", "default": 50 },
        "surgeFare": { "type": "number", "default": 0 },
        "busMultiplier": { "type": "number", "default": 1.0 },
        "miniBusMultiplier": { "type": "number", "default": 1.2 },
        "vanMultiplier": { "type": "number", "default": 1.5 },
        "isActive": { "type": "boolean" },
        "status": { "type": "string", "enum": ["suggested", "active", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["routeName", "stops", "city"]
    }
  },
  "auth": {
    "providers": ["phone", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Historical and active trip records."
    },
    "/routes/{routeId}": {
      "schema": "Route",
      "description": "Optimized shuttle route templates."
    }
  }
}
