
{
  "entities": {
    "User": {
      "title": "User",
      "description": "A student rider, driver, or administrative user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "collegeName": { "type": "string" },
        "studentId": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "emergencyContactName": { "type": "string" },
        "emergencyContactPhone": { "type": "string" },
        "city": { "type": "string", "enum": ["Vizag", "Vizianagaram"] },
        "role": { "type": "string", "enum": ["rider", "admin", "driver"] },
        "status": { "type": "string", "enum": ["available", "on-trip", "offline"] },
        "photoUrl": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "vehicleType": { "type": "string", "enum": ["Bus", "Mini-Bus", "Van"] },
        "aadhaarNumber": { "type": "string" },
        "yearsOfExperience": { "type": "number" },
        "currentLat": { "type": "number" },
        "currentLng": { "type": "number" },
        "activeOtp": { "type": "string" },
        "destinationStopName": { "type": "string" },
        "totalEarnings": { "type": "number", "default": 0 },
        "loyaltyPoints": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "role"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A record of a shuttle trip.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "routeName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
        "riderCount": { "type": "number", "default": 0 },
        "maxCapacity": { "type": "number", "default": 40 },
        "farePerRider": { "type": "number" },
        "passengers": { "type": "array", "items": { "type": "string" } },
        "verifiedPassengers": { "type": "array", "items": { "type": "string" } },
        "noShowReports": { "type": "array", "items": { "type": "string" } },
        "totalYield": { "type": "number" },
        "driverShare": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      },
      "required": ["driverId", "routeName", "status"]
    }
  },
  "auth": {
    "providers": ["phone", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles." },
    "/trips/{tripId}": { "schema": "Trip", "description": "Trip records." },
    "/routes/{routeId}": { "schema": "Route", "description": "Route definitions." },
    "/vouchers/{voucherId}": { "schema": "Voucher", "description": "Discount vouchers." },
    "/config/global": { "schema": "AppConfig", "description": "Global network settings." }
  }
}
