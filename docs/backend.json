
{
  "entities": {
    "User": {
      "title": "User",
      "description": "A community member (rider), operator (driver), or administrative profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "identityNumber": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "emergencyContactName": { "type": "string" },
        "emergencyContactPhone": { "type": "string" },
        "role": { "type": "string", "enum": ["rider", "admin", "driver"] },
        "status": { "type": "string", "enum": ["available", "on-trip", "offline"] },
        "isVerified": { "type": "boolean", "default": false },
        "photoUrl": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "vehicleType": { "type": "string", "enum": ["5 Seater", "7 Seater", "Mini-Bus"] },
        "seatingCapacity": { "type": "number" },
        "aadhaarNumber": { "type": "string" },
        "currentLat": { "type": "number" },
        "currentLng": { "type": "number" },
        "activeOtp": { "type": "string" },
        "destinationStopName": { "type": "string" },
        "totalEarnings": { "type": "number", "default": 0 },
        "loyaltyPoints": { "type": "number", "default": 0 },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "role"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A record of a community mobility trip.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "driverPhoto": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "vehicleType": { "type": "string" },
        "routeName": { "type": "string" },
        "scheduledDate": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "scheduled", "on-trip", "completed"] },
        "riderCount": { "type": "number", "default": 0 },
        "maxCapacity": { "type": "number", "default": 7 },
        "farePerRider": { "type": "number" },
        "passengerManifest": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "uid": { "type": "string" },
              "name": { "type": "string" },
              "pickup": { "type": "string" },
              "destination": { "type": "string" },
              "bookingDate": { "type": "string" },
              "farePaid": { "type": "number" }
            }
          }
        },
        "verifiedPassengers": { "type": "array", "items": { "type": "string" } },
        "totalYield": { "type": "number" },
        "currentLat": { "type": "number" },
        "currentLng": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      },
      "required": ["routeName", "status"]
    },
    "Route": {
      "title": "Route",
      "description": "A community transit corridor definition with landmark stops.",
      "type": "object",
      "properties": {
        "routeName": { "type": "string" },
        "baseFare": { "type": "number" },
        "stops": { 
          "type": "array", 
          "items": { 
            "type": "object", 
            "properties": { "name": { "type": "string" } } 
          } 
        },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global settings for the mobility grid.",
      "type": "object",
      "properties": {
        "primaryUpiId": { "type": "string" },
        "secondaryUpiId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["phone", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User and operator profiles." },
    "/trips/{tripId}": { "schema": "Trip", "description": "Grid trip records." },
    "/routes/{routeId}": { "schema": "Route", "description": "Transit corridors." },
    "/vouchers/{voucherId}": { "schema": "Voucher", "description": "Discount vouchers." },
    "/config/global": { "schema": "AppConfig", "description": "Global grid settings." }
  }
}
