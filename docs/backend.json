
{
  "entities": {
    "User": {
      "title": "User",
      "description": "A student rider, driver, or administrative user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "collegeName": { "type": "string" },
        "studentId": { "type": "string" },
        "city": { "type": "string", "enum": ["Vizag", "Vizianagaram"] },
        "role": { "type": "string", "enum": ["rider", "admin", "driver"] },
        "status": { "type": "string", "enum": ["available", "on-trip", "offline"], "description": "Current status for drivers." },
        "currentLat": { "type": "number" },
        "currentLng": { "type": "number" },
        "totalTrips": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "role"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A record of a shuttle trip.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "routeName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
        "riderCount": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" }
      },
      "required": ["driverId", "routeName", "status"]
    },
    "Route": {
      "title": "Route",
      "description": "An optimized shuttle route configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "routeName": { "type": "string" },
        "description": { "type": "string" },
        "stops": { "type": "array", "items": { "type": "string" } },
        "schedule": { "type": "string" },
        "estimatedDuration": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["routeName", "stops"]
    }
  },
  "auth": {
    "providers": ["phone", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document identified by Firebase Auth UID."
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Historical and active trip records."
    },
    "/routes/{routeId}": {
      "schema": "Route",
      "description": "Optimized shuttle route templates."
    }
  }
}
